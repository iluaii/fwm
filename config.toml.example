# fwm configuration file
# ~/.config/fwm/config.toml

# Realistic preset: earth gravity (9.8 m/s^2 at 100 px/m scale), dull heavy
# bounce, long weighty glides in zero-g.
# Old "cartoon" feel: friction 0.97, restitution 0.75, gravity 200.
[physics]
friction              = 0.985
mass_density          = 0.0005
throw_speed_multiplier = 0.65
max_throw_speed       = 1800.0
stop_speed_threshold  = 1.0
restitution           = 0.3
gravity               = 981.0
tick_rate             = 60.0

# Window decorations: focus border colors ("#RRGGBB" or "#RRGGBBAA"),
# border width (0 disables) and map fade-in duration (0 disables).
[decor]
border_width = 2
col_active   = "#7aa2f7"
col_inactive = "#3b4261"
# Window appear/close animation, ms. Short values read as a pop rather than a
# fade — 260 is a calm default; 0 disables.
fade_in_ms   = 260.0
# Cross-fade when the wallpaper is swapped at runtime (picker); 0 = instant cut.
wallpaper_fade_ms = 420.0
# Island fill opacity (0..1), separate for the tray bar and the app launcher.
tray_opacity     = 0.92
launcher_opacity = 0.92
# Launcher icon theme. "" = auto: gtk-3.0 settings.ini, then hicolor.
icon_theme = ""
# Where the UI palette comes from.
#   "config"    — the colours above plus the built-in dark scheme (default)
#   "wallpaper" — derive it from the first [[wallpaper]] image: the tray,
#                 panels, launcher and tab bars are tinted toward its dominant
#                 hue, and the focus border / desktop marker / tab underline
#                 take its most vivid colour. Islands are always kept dark, so
#                 text stays readable no matter the image. A greyscale
#                 wallpaper falls back to the colours above.
color_source     = "config"
# 0..1: how far the islands move toward the wallpaper hue. 0 = untinted
# (accent only), 1 = as far as the palette allows.
tint_strength    = 0.4

# Hyprland-style tiling: gaps and the tile-glide animation.
# anim_speed is 1/s (12 ~ 250ms glide); 0 disables the animation.
[tiling]
gaps_in    = 6
gaps_out   = 12
anim_speed = 12.0

# Desktop-switch camera slide (ease-in-out). 0 = instant snap.
# free_speed is a different motion: how tightly the camera follows a HELD
# move_camera: bind (1/s, higher = tighter, lower = more coasting).
[camera]
anim_ms    = 350.0
free_speed = 14.0

# What an app is allowed to do when it asks to be raised (xdg-activation):
# a link opening in an already-running browser, a chat client jumping to a
# message. The annoying part is not the focus change but the camera leaving
# the desktop you are working on, so these are separate:
#   "never"        — ignore such requests entirely
#   "same_desktop" — (default) focus it only if it is already on screen
#   "always"       — focus it and pan the camera to wherever it lives
[focus]
on_activate = "same_desktop"

# Impact effects, both scaled by collision speed so gentle bumps stay subtle.
#
# camera_shake jolts the wallpaper and windows when something lands hard (the
# tray and panels never move — jittering UI reads as a glitch, not as impact).
# OFF by default: moving the whole view on every landing is intrusive while
# you are actually working. Set 1.0 for the default strength, up to 4.
#
# squash deforms a window on impact — compressed along the contact, bulging
# across it, springing back through a smaller overshoot. 0 disables.
[effects]
camera_shake = 0.0
squash       = 1.0

# When a restarted fwm should put your applications back. fwm records what is
# running and on which desktop, and relaunches it — the applications restart,
# they do not resume, so anything unsaved inside them is still lost.
#
#   "crash"  — (default) only when the last run ended badly. fwm deletes the
#              record on a clean shutdown, so a normal logout gives you a clean
#              desktop and only a crash brings the windows back.
#   "always" — every start, including a normal login.
#   "never"  — nothing is recorded and nothing is relaunched.
[session]
restore = "crash"

[input]
# xkb keyboard: several layouts + a grp:* option = layout switching.
# The FIRST layout must stay Latin so binds keep working on any layout.
kbd_layout  = "us,ru"
kbd_options = "grp:alt_shift_toggle"
# kbd_variant = ""
repeat_rate  = 25
repeat_delay = 600

[binds]
# format: "mod+key" = "action"
# mod keys: super, alt, shift, ctrl
# system actions: killclient, toggle_tiling, fake_fullscreen, real_fullscreen,
#                 pin_window, toggle_nocollide, toggle_nocollide_all,
#                 toggle_tiling_all, toggle_floating, toggle_floating_all,
#                 calm_all, cycle_gravity,
#                 show_hints, show_errors, reload_config,
#                 wallpaper_picker, launcher, EXIT
# tiling:         toggle_split, tile_focus:l|r|u|d, tile_move:l|r|u|d
# tab-stacks:     group_toggle, group_next, group_prev, group_add
#
# A broken config never costs you the session: fwm falls back to built-in
# keybindings, reports the problem in a tray pill (click it for details) and
# keeps running. Fix the file and press super+shift+r to reload.
# spawn actions:  spawn:command arg1 arg2 ...
# camera:         move_camera:-50  move_camera:50
# workspace:      view:0 .. view:9
# move a window:  move_to:0 .. move_to:9        (send it there, stay put)
#                 move_to_view:0 .. :9         (send it there and follow)
# In physics and floating modes you can also just drag a window across the
# desktop edge; in tiling you cannot, because the layout owns its geometry —
# these actions are the way to move a tiled window out.

"super+Return"       = "spawn:kitty"
#"super+space"        = "spawn:rofi -show drun -normal-window"
"super+q"            = "killclient"
"super+t"            = "toggle_tiling"
# The third mode: a plain desktop environment. Windows keep the position you
# drop them at and overlap freely — no gravity, no shoving, no layout. Handy
# for the stretch of an afternoon where you just want the windows to sit still.
# Per-window pin/nocollide are left untouched, so leaving the mode gives back
# whatever you had toggled by hand. "toggle_floating_all" does every desktop.
"super+alt+space"    = "toggle_floating"
"super+space"            = "launcher"
"super+d"            = "fake_fullscreen"
"super+f"            = "real_fullscreen"
"super+h"            = "move_camera:-50"
"super+l"            = "move_camera:50"
"super+p"            = "pin_window"
"super+n"            = "toggle_nocollide"
# Global versions: every window / every desktop at once, for when an app
# launcher opens a pile of windows and toggling them one by one is hopeless.
"super+shift+n"      = "toggle_nocollide_all"
"super+shift+t"      = "toggle_tiling_all"
"super+shift+c"      = "calm_all"
"super+g"            = "cycle_gravity"
"super+shift+Escape" = "EXIT"
# Bound to the physical "/" key, not to the "?" symbol: a symbol bind lands on
# a different key per layout (US shift+/, RU shift+7), while "slash" resolves
# through the layout-0 fallback and stays put on every layout.
"super+shift+slash"  = "show_hints"
"super+shift+r"      = "reload_config"
"super+shift+p"      = "wallpaper_picker"
# Lock the screen. fwm implements ext-session-lock-v1; the lock screen itself
# is drawn by an external client (hyprlock, swaylock), so this is a plain spawn.
"super+shift+l"      = "spawn:hyprlock"
# Tiling control (Hyprland-style; only active on tiling desktops)
"super+Left"         = "tile_focus:l"
"super+Right"        = "tile_focus:r"
"super+Up"           = "tile_focus:u"
"super+Down"         = "tile_focus:d"
"super+shift+Left"   = "tile_move:l"
"super+shift+Right"  = "tile_move:r"
"super+shift+Up"     = "tile_move:u"
"super+shift+Down"   = "tile_move:d"
"super+s"            = "toggle_split"
# Tab-stacks (Hyprland-style groups)
"super+w"            = "group_toggle"
"super+Tab"          = "group_next"
"super+shift+Tab"    = "group_prev"
"super+shift+w"      = "group_add"
# Send the focused window to a desktop (i3/sway convention). The camera stays
# where it is; use move_to_view: to travel with the window instead.
"super+shift+1"      = "move_to:0"
"super+shift+2"      = "move_to:1"
"super+shift+3"      = "move_to:2"
"super+shift+4"      = "move_to:3"
"super+shift+5"      = "move_to:4"
"super+shift+6"      = "move_to:5"
"super+shift+7"      = "move_to:6"
"super+shift+8"      = "move_to:7"
"super+shift+9"      = "move_to:8"
"super+shift+0"      = "move_to:9"
"super+1"            = "view:0"
"super+2"            = "view:1"
"super+3"            = "view:2"
"super+4"            = "view:3"
"super+5"            = "view:4"
"super+6"            = "view:5"
"super+7"            = "view:6"
"super+8"            = "view:7"
"super+9"            = "view:8"
"super+0"            = "view:9"

# Built-in wallpaper picker: which folder to browse (flat, no recursion).
# The pick is remembered in ~/.local/state/fwm/wallpaper and overrides the
# first [[wallpaper]] layer on the next start; this file is never rewritten.
# Deleting that state file goes back to the wallpaper configured here.
[wallpaper_picker]
dir = "~/Pictures"

# Window rules: per-window overrides applied once, when the window opens.
# Match on app_id and/or title with POSIX extended regexes — the same anchored
# style as Hyprland's `class:^(mpv)$`. A rule with both matchers needs both to
# hit; rules are applied in file order, so a later one wins field by field.
#
# Properties: nocollide, pin (booleans) and desktop (0..9).
#
# There is no per-window "float" on purpose: tiling here is a property of the
# DESKTOP, not of the window, so such a rule could not be honoured. Use
# toggle_tiling on the desktop instead.
#
#[[rule]]
#app_id    = "^mpv$"
#nocollide = true          # video should not get shoved around by physics
#
#[[rule]]
#app_id  = "^(Slack|discord)$"
#desktop = 3               # chat always opens on desktop 4
#
#[[rule]]
#title = "^Picture-in-Picture$"
#pin   = true

# Anything above with a numeric or colour value can also be changed live,
# without editing this file:
#
#   fwmctl config                        # list every option with its value
#   fwmctl set physics.gravity 200       # watch a window fall in slow motion
#   fwmctl set decor.col_active "#ff0000"
#
# Those changes last until the session ends or you reload (super+shift+r) —
# this file is never rewritten, so the comments you are reading survive.

# Wallpaper. fit = "cover" (fill+crop, static) | "contain" (whole image,
# letterboxed, static) | "pan" (walk across the image as you switch desktops).
# "pan" moves only images wide enough to stick out past the screen at native
# scale (roughly: wider than your screen's aspect). Those walk with nothing
# cropped. A narrower image is shown still rather than zoomed in, because
# buying travel means cropping its height — that trade is yours to make:
#   pan_crop = 0.25   # give up 25% of the height in exchange for travel
#   zoom     = 1.6    # or set the render width directly (screen_w * zoom)
# The log line for each layer reports the travel and crop you ended up with.

# Commented out on purpose: a placeholder path would be reported as a config
# problem (the tray pill) on a fresh install. Point it at a real image and
# uncomment, or just pick one with super+shift+p.
#[[wallpaper]]
#path = "/path/to/wallpaper.png"
#fit  = "pan"

# fwm configuration file
# ~/.config/fwm/config.toml

# Realistic preset: earth gravity (9.8 m/s^2 at 100 px/m scale), dull heavy
# bounce, long weighty glides in zero-g.
# Old "cartoon" feel: friction 0.97, restitution 0.75, gravity 200.
[physics]
friction              = 0.985
mass_density          = 0.0005
throw_speed_multiplier = 0.65
max_throw_speed       = 1800.0
stop_speed_threshold  = 1.0
restitution           = 0.3
gravity               = 981.0
tick_rate             = 60.0

# Window decorations: focus border colors ("#RRGGBB" or "#RRGGBBAA"),
# border width (0 disables) and map fade-in duration (0 disables).
[decor]
border_width = 2
col_active   = "#7aa2f7"
col_inactive = "#3b4261"
# Window appear/close animation, ms. Short values read as a pop rather than a
# fade — 260 is a calm default; 0 disables.
fade_in_ms   = 260.0
# Cross-fade when the wallpaper is swapped at runtime (picker); 0 = instant cut.
wallpaper_fade_ms = 420.0
# Island fill opacity (0..1), separate for the tray bar and the app launcher.
tray_opacity     = 0.92
launcher_opacity = 0.92
# Launcher icon theme. "" = auto: gtk-3.0 settings.ini, then hicolor.
icon_theme = ""
# Where the UI palette comes from.
#   "config"    — the colours above plus the built-in dark scheme (default)
#   "wallpaper" — derive it from the first [[wallpaper]] image: the tray,
#                 panels, launcher and tab bars are tinted toward its dominant
#                 hue, and the focus border / desktop marker / tab underline
#                 take its most vivid colour. Islands are always kept dark, so
#                 text stays readable no matter the image. A greyscale
#                 wallpaper falls back to the colours above.
color_source     = "config"
# 0..1: how far the islands move toward the wallpaper hue. 0 = untinted
# (accent only), 1 = as far as the palette allows.
tint_strength    = 0.4

# Hyprland-style tiling: gaps and the tile-glide animation.
# anim_speed is 1/s (12 ~ 250ms glide); 0 disables the animation.
[tiling]
gaps_in    = 6
gaps_out   = 12
anim_speed = 12.0

# Desktop-switch camera slide (ease-in-out). 0 = instant snap.
[camera]
anim_ms = 350.0

[input]
# xkb keyboard: several layouts + a grp:* option = layout switching.
# The FIRST layout must stay Latin so binds keep working on any layout.
kbd_layout  = "us,ru"
kbd_options = "grp:alt_shift_toggle"
# kbd_variant = ""
repeat_rate  = 25
repeat_delay = 600

[binds]
# format: "mod+key" = "action"
# mod keys: super, alt, shift, ctrl
# system actions: killclient, toggle_tiling, fake_fullscreen, real_fullscreen,
#                 pin_window, toggle_nocollide, calm_all, cycle_gravity,
#                 show_hints, show_errors, reload_config,
#                 wallpaper_picker, EXIT
#
# A broken config never costs you the session: fwm falls back to built-in
# keybindings, reports the problem in a tray pill (click it for details) and
# keeps running. Fix the file and press super+shift+r to reload.
# spawn actions:  spawn:command arg1 arg2 ...
# camera:         move_camera:-50  move_camera:50
# workspace:      view:0 .. view:9

"super+Return"       = "spawn:kitty"
#"super+space"        = "spawn:rofi -show drun -normal-window"
"super+q"            = "killclient"
"super+t"            = "toggle_tiling"
"super+space"            = "launcher"
"super+d"            = "fake_fullscreen"
"super+f"            = "real_fullscreen"
"super+h"            = "move_camera:-50"
"super+l"            = "move_camera:50"
"super+p"            = "pin_window"
"super+n"            = "toggle_nocollide"
"super+shift+c"      = "calm_all"
"super+g"            = "cycle_gravity"
"super+shift+Escape" = "EXIT"
"super+shift+question" = "show_hints"
"super+shift+r"      = "reload_config"
"super+shift+p"      = "wallpaper_picker"
# Tiling control (Hyprland-style; only active on tiling desktops)
"super+Left"         = "tile_focus:l"
"super+Right"        = "tile_focus:r"
"super+Up"           = "tile_focus:u"
"super+Down"         = "tile_focus:d"
"super+shift+Left"   = "tile_move:l"
"super+shift+Right"  = "tile_move:r"
"super+shift+Up"     = "tile_move:u"
"super+shift+Down"   = "tile_move:d"
"super+s"            = "toggle_split"
# Tab-stacks (Hyprland-style groups)
"super+w"            = "group_toggle"
"super+Tab"          = "group_next"
"super+shift+Tab"    = "group_prev"
"super+shift+w"      = "group_add"
"super+1"            = "view:0"
"super+2"            = "view:1"
"super+3"            = "view:2"
"super+4"            = "view:3"
"super+5"            = "view:4"
"super+6"            = "view:5"
"super+7"            = "view:6"
"super+8"            = "view:7"
"super+9"            = "view:8"
"super+0"            = "view:9"

# Built-in wallpaper picker: which folder to browse (flat, no recursion).
# The pick is remembered in ~/.local/state/fwm/wallpaper and overrides the
# first [[wallpaper]] layer on the next start; this file is never rewritten.
# Deleting that state file goes back to the wallpaper configured here.
[wallpaper_picker]
dir = "~/Pictures"

# Wallpaper. fit = "cover" (fill+crop, static) | "contain" (whole image,
# letterboxed, static) | "pan" (walk across the image as you switch desktops).
# "pan" moves only images wide enough to stick out past the screen at native
# scale (roughly: wider than your screen's aspect). Those walk with nothing
# cropped. A narrower image is shown still rather than zoomed in, because
# buying travel means cropping its height — that trade is yours to make:
#   pan_crop = 0.25   # give up 25% of the height in exchange for travel
#   zoom     = 1.6    # or set the render width directly (screen_w * zoom)
# The log line for each layer reports the travel and crop you ended up with.

[[wallpaper]]
path = "/path/to/wallpaper.png"
fit  = "pan"
